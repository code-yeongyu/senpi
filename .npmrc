; pnpm-only settings. npm/bun ignore keys they don't recognize.
; node-linker=hoisted mirrors npm's flat install so transitive deps stay
; resolvable across workspaces without declaring every single one directly.
; link-workspace-packages=deep lets semver ranges ('^0.67.6') resolve to the
; local workspace copy instead of hitting the public npm registry; without
; it, pnpm 10 tries to fetch '@code-yeongyu/senpi' from npmjs.org and fails.
node-linker=hoisted
link-workspace-packages=deep
prefer-workspace-packages=true
